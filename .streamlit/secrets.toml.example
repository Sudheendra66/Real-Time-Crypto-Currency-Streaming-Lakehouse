# ============================================================
# Streamlit Secrets Template
# ============================================================
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit .streamlit/secrets.toml to version control.
#
# In Streamlit Cloud, add these values via the app dashboard:
#   https://share.streamlit.io → Your App → Settings → Secrets
# ============================================================

[databricks]
# Databricks SQL Warehouse connection details
server_hostname = "your-workspace.azuredatabricks.net"
http_path = "/sql/1.0/warehouses/your-warehouse-id"
access_token = "dapi-your-databricks-access-token"
catalog = "hive_metastore"
schema = "default"

# ============================================================
# Optional: Azure Storage (ADLS Gen2) - used in Databricks notebooks
# ============================================================
[azure_storage]
storage_account = "your-storage-account-name"
access_key = "your-storage-account-key"

# ============================================================
# Optional: Event Hub / Kafka connection (Producer & Databricks streaming)
# ============================================================
[eventhub]
connection_string = "Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=your-policy;SharedAccessKey=your-key"
event_hub_name = "your-event-hub-name"
namespace = "your-namespace"
sas_key_name = "your-sas-policy-name"
sas_key = "your-sas-key"
bootstrap_servers = "your-namespace.servicebus.windows.net:9093"