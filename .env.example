# ============================================================
# EVENT HUBS / KAFKA (Producer)
# ============================================================
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=your-policy;SharedAccessKey=your-key
EVENT_HUB_NAME=your-event-hub-name

# ============================================================
# AZURE STORAGE (ADLS Gen2) — used in Databricks notebooks
# ============================================================
AZURE_STORAGE_ACCOUNT=your-storage-account-name
AZURE_STORAGE_ACCESS_KEY=your-storage-account-key

# ============================================================
# DATABRICKS — SQL Warehouse connection (Streamlit dashboard & dbt)
# ============================================================
DATABRICKS_SERVER_HOSTNAME=your-workspace-url.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_ACCESS_TOKEN=dapi-your-databricks-token
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=default

# ============================================================
# EVENT HUBS NAMESPACE (for Databricks Kafka streaming)
# ============================================================
EVENT_HUB_NAMESPACE=your-namespace
EVENT_HUB_NAMESPACE_SAS_KEY_NAME=your-sas-policy-name
EVENT_HUB_NAMESPACE_SAS_KEY=your-sas-key
KAFKA_BOOTSTRAP_SERVERS=your-namespace.servicebus.windows.net:9093